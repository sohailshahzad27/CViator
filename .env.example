# .env.example — root-level secrets consumed by docker-compose.
# Copy to .env and fill in real values before running docker-compose.
# NEVER commit .env to git.

# ── PostgreSQL ──────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change-me-db-password
DB_NAME=cviator

# ── JWT ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Admin signup gate ───────────────────────────────────────────────
ADMIN_SIGNUP_CODE=replace-with-a-secret-code

# ── URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── SMTP (leave blank to skip email sending and log links to console) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
