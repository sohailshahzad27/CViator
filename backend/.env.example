# backend/.env.example
# Copy to backend/.env for running the backend directly (without Docker).
# NEVER commit backend/.env to git.

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────────────────
# Use DB_HOST=postgres when running via docker-compose; localhost otherwise.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cviator

# ── JWT ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Root administrator ──────────────────────────────────────────────
# Email of the root admin. The first admin signup matching this address
# is auto-approved; all other admins require root approval.
ROOT_ADMIN_EMAIL=root.admin@giki.edu.pk

# ── SMTP (leave blank to log email links to console instead of sending) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
