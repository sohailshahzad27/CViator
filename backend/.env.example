# backend/.env.example
# Copy this file to backend/.env and edit as needed.
# Never commit the real .env — it's in .gitignore.

# ── Server ─────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────
# When running with docker-compose, use DB_HOST=postgres.
# When running the backend directly against a local Postgres, use localhost.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cviator

# ── JWT ────────────────────────────────────────────────
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
